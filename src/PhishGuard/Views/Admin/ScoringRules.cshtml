@model List<PhishGuard.Models.ScoringRule>
@using PhishGuard.Models
@{ ViewData["Title"] = "Scoring Rules"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Scoring Rules</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Dashboard</a>
</div>

<p class="text-muted">These rules control how the scoring engine evaluates incoming emails. Toggle rules on or off to adjust detection sensitivity.</p>

@{
    var grouped = Model.GroupBy(r => r.Dimension).OrderBy(g => g.Key);
}

@foreach (var group in grouped)
{
    var dimensionName = group.Key switch
    {
        ScoringDimension.ThreatFeed => "Threat Feed",
        ScoringDimension.DomainReputation => "Domain Reputation",
        ScoringDimension.LanguageAnalysis => "Language Analysis",
        ScoringDimension.BehavioralTiming => "Behavioral Timing",
        ScoringDimension.HtmlFingerprint => "HTML Fingerprint",
        ScoringDimension.SenderHistory => "Sender History",
        _ => group.Key.ToString()
    };

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">@dimensionName</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Rule</th>
                        <th>Description</th>
                        <th>Pattern</th>
                        <th>Score</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rule in group)
                    {
                        <tr class="@(!rule.IsActive ? "table-secondary" : "")">
                            <td><strong>@rule.RuleName</strong></td>
                            <td><small>@rule.RuleDescription</small></td>
                            <td><code>@(rule.Pattern ?? "-")</code></td>
                            <td><strong>@rule.ScoreValue</strong></td>
                            <td>
                                <span class="badge @(rule.IsActive ? "bg-success" : "bg-secondary")">
                                    @(rule.IsActive ? "Active" : "Disabled")
                                </span>
                            </td>
                            <td>
                                <form asp-action="ToggleRule" method="post">
                                    <input type="hidden" name="ruleId" value="@rule.RuleId" />
                                    <button type="submit" class="btn btn-sm @(rule.IsActive ? "btn-outline-secondary" : "btn-outline-success")">
                                        @(rule.IsActive ? "Disable" : "Enable")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
