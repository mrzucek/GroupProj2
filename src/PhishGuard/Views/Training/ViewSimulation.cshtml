@model PhishGuard.Models.SimulationEmail
@{ ViewData["Title"] = Model.Campaign.TemplateSubject; }

<div class="pn-page" style="max-width:800px;">
    <div class="pn-page-header">
        <div>
            <h1 class="pn-page-title">Simulated Email</h1>
            <p class="pn-page-subtitle">Review this email as if it landed in your real inbox.</p>
        </div>
        <div class="pn-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Training</a>
        </div>
    </div>

    <!-- Simulated email card — styled like the inbox detail pane -->
    <div class="pn-card">
        <div class="pn-card-body">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <div style="font-weight:600;font-size:0.95rem;">@Model.Campaign.TemplateSender</div>
                    <div class="text-muted" style="font-size:0.82rem;">To: me</div>
                </div>
                <span class="text-muted" style="font-size:0.82rem;">@Model.SentAt.ToString("MMM dd, yyyy h:mm tt")</span>
            </div>
            <h2 style="font-size:1.15rem;font-weight:700;margin:0 0 16px;">@Model.Campaign.TemplateSubject</h2>
            <div style="white-space:pre-wrap;line-height:1.7;color:#444;font-size:0.9rem;border-top:1px solid var(--pn-border);padding-top:16px;">@Model.Campaign.TemplateBody</div>
        </div>
    </div>

    @if (Model.Result == PhishGuard.Models.SimulationResult.Pending)
    {
        <div class="pn-card">
            <div class="pn-card-body">
                <p class="text-muted" style="font-size:0.85rem;margin:0 0 12px;">
                    Treat this like a real email. If you think it's legitimate, click the link. If you think it's phishing, report it.
                </p>
                <div class="d-flex gap-2">
                    <form asp-action="SimulationClicked" asp-route-id="@Model.SimulationId" method="post">
                        <button type="submit" class="btn pn-btn">Click Link in Email</button>
                    </form>
                    <form asp-action="SimulationReported" asp-route-id="@Model.SimulationId" method="post">
                        <button type="submit" class="btn pn-btn-outline-danger">Report as Phishing</button>
                    </form>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="pn-card">
            <div class="pn-card-body text-center" style="padding:20px;">
                You've already responded to this simulation.
                <a asp-action="SimulationResult" asp-route-id="@Model.SimulationId" class="pn-auth-link" style="margin-left:4px;">View result</a>
            </div>
        </div>
    }
</div>
