@model List<PhishGuard.Services.LeaderboardEntry>
@{
    ViewData["Title"] = "Leaderboard";
    var currentId = (int)ViewBag.CurrentEmployeeId;
}

<div class="pn-page">
    <div class="pn-page-header">
        <div>
            <h1 class="pn-page-title">Leaderboard</h1>
            <p class="pn-page-subtitle">Top performers based on training points and detection rate.</p>
        </div>
        <div class="pn-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Training</a>
        </div>
    </div>

@if (!Model.Any())
{
    <div class="pn-card">
        <div class="pn-card-body text-center" style="padding:28px;">
            <div style="font-weight:800;">No training data yet</div>
            <div class="text-muted" style="margin-top:6px;">Start training exercises to appear on the leaderboard.</div>
        </div>
    </div>
}
else
{
    <!-- Top 3 Podium -->
    @if (Model.Count >= 3)
    {
        <div class="row mb-3 justify-content-center">
            @for (int i = 0; i < Math.Min(3, Model.Count); i++)
            {
                var entry = Model[i];
                var medal = i switch { 0 => "1st", 1 => "2nd", _ => "3rd" };
                var isMe = entry.EmployeeId == currentId;

                <div class="col-md-4">
                    <div class="pn-card" style="border-top:3px solid @(i == 0 ? "#d4a843" : i == 1 ? "#94a3b8" : "#1ca8c7");">
                        <div class="pn-card-body text-center">
                            <div class="text-muted" style="font-size:0.72rem;letter-spacing:0.08em;text-transform:uppercase;">@medal</div>
                            <div style="font-weight:800;font-size:1.05rem;margin-top:6px; color:@(isMe ? "var(--pn-blue)" : "var(--pn-text)")">
                                @entry.DisplayName @(isMe ? "(You)" : "")
                            </div>
                            @if (entry.Department != null)
                            {
                                <div class="text-muted" style="font-size:0.8rem;margin-top:2px;">@entry.Department</div>
                            }
                            <div style="font-weight:800;font-size:1.25rem;margin-top:8px;color:var(--pn-blue);">@entry.ScorePoints pts</div>
                            <div class="text-muted" style="font-size:0.8rem;margin-top:4px;">Best streak: @entry.BestStreak • Detection: @entry.ReportRate%</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Full Table -->
    <div class="pn-card">
        <div class="table-responsive">
            <table class="pn-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Employee</th>
                        <th>Department</th>
                        <th>Points</th>
                        <th>Streak</th>
                        <th>Difficulty</th>
                        <th>Caught</th>
                        <th>Missed</th>
                        <th>Detection Rate</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var entry = Model[i];
                        var isMe = entry.EmployeeId == currentId;
                        <tr style="@(isMe ? "background: rgba(28,168,199,0.08);" : "")">
                            <td><strong>#@(i + 1)</strong></td>
                            <td>
                                @entry.DisplayName
                                @if (isMe) { <span class="inbox-tag inbox-tag--muted" style="margin-left:6px;">You</span> }
                            </td>
                            <td>@(entry.Department ?? "-")</td>
                            <td><strong>@entry.ScorePoints</strong></td>
                            <td>@entry.CurrentStreak (best: @entry.BestStreak)</td>
                            <td>
                                <span class="inbox-tag inbox-tag--muted">@entry.CurrentDifficulty</span>
                            </td>
                            <td class="text-success">@entry.TotalReported</td>
                            <td class="text-danger">@entry.TotalClicked</td>
                            <td>
                                @{
                                    var rateColor = entry.ReportRate >= 80 ? "text-success" : entry.ReportRate >= 50 ? "text-warning" : "text-danger";
                                }
                                <strong class="@rateColor">@entry.ReportRate%</strong>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

</div>
