@using PhishGuard.Models
@{
    ViewData["Title"] = "Security Training";
    var training = ViewBag.Training as PhishGuard.Models.EmployeeTraining;
    var pending = ViewBag.Pending as List<SimulationEmail> ?? new();
    var history = ViewBag.History as List<SimulationEmail> ?? new();
}

<div class="pn-page">
    <div class="pn-page-header">
        <div>
            <h1 class="pn-page-title">Training</h1>
            <p class="pn-page-subtitle">Practice spotting simulated phishing emails and build your streak.</p>
        </div>
        <div class="pn-actions">
            <a asp-action="Leaderboard" class="btn btn-outline-secondary">Leaderboard</a>
            <form asp-action="SendSimulation" method="post" class="d-inline">
                <button type="submit" class="btn pn-btn">Send Me a Test Phish</button>
            </form>
        </div>
    </div>

@if (training != null)
{
    <div class="pn-kpi-grid" style="margin-bottom:14px;">
        <div class="pn-kpi">
            <div class="pn-kpi-value" style="color:var(--pn-blue);">@training.ScorePoints</div>
            <div class="pn-kpi-label">Points</div>
        </div>
        <div class="pn-kpi">
            <div class="pn-kpi-value">@training.CurrentStreak</div>
            <div class="pn-kpi-label">Current Streak</div>
        </div>
        <div class="pn-kpi">
            <div class="pn-kpi-value">@training.BestStreak</div>
            <div class="pn-kpi-label">Best Streak</div>
        </div>
        <div class="pn-kpi">
            <div class="pn-kpi-value" style="color:#1ca8c7;">@training.TotalCorrectlyReported</div>
            <div class="pn-kpi-label">Caught</div>
        </div>
        <div class="pn-kpi">
            <div class="pn-kpi-value" style="color:#c0392b;">@training.TotalClicked</div>
            <div class="pn-kpi-label">Missed</div>
        </div>
        <div class="pn-kpi">
            @{
                var diffColor = training.CurrentDifficulty switch
                {
                    Difficulty.Easy => "#50b583",
                    Difficulty.Medium => "#d4920a",
                    Difficulty.Hard => "#c0392b",
                    Difficulty.Expert => "#6f42c1",
                    _ => "var(--pn-text)"
                };
            }
            <div class="pn-kpi-value" style="color:@diffColor">@training.CurrentDifficulty</div>
            <div class="pn-kpi-label">Difficulty</div>
        </div>
    </div>
}

<!-- Pending Simulations -->
@if (pending.Any())
{
    <div class="pn-card">
        <div class="pn-card-header" style="background: rgba(212,146,10,0.12);">
            <h2 class="pn-card-title">Incoming — Review Required (@pending.Count)</h2>
        </div>
        <div class="list-group list-group-flush">
            @foreach (var sim in pending)
            {
                <a asp-action="ViewSimulation" asp-route-id="@sim.SimulationId" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between">
                        <div>
                            <strong>@sim.Campaign.TemplateSender</strong>
                            <br />
                            <span>@sim.Campaign.TemplateSubject</span>
                        </div>
                        <div class="text-end">
                            <small class="text-muted">@sim.SentAt.ToString("MMM dd, h:mm tt")</small>
                            <br />
                            <span class="badge bg-info">New</span>
                        </div>
                    </div>
                </a>
            }
        </div>
    </div>
}
else
{
    <div class="pn-card">
        <div class="pn-card-body text-center" style="padding:24px;">
            <div style="font-weight:800;">No pending test emails</div>
            <div class="text-muted" style="margin-top:6px;">Click “Send Me a Test Phish” to receive a simulated phishing email and practice your detection skills.</div>
        </div>
    </div>
}

<!-- History -->
<div class="pn-card">
    <div class="pn-card-header">
        <h2 class="pn-card-title">Training History</h2>
    </div>
    @if (history.Any())
    {
        <div class="table-responsive">
            <table class="pn-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Campaign</th>
                        <th>Difficulty</th>
                        <th>Result</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sim in history)
                    {
                        var resultText = sim.Result switch
                        {
                            SimulationResult.Reported => "Caught it!",
                            SimulationResult.Clicked => "Fell for it",
                            SimulationResult.NoAction => "Ignored",
                            _ => "Pending"
                        };
                        var resultPillClass = sim.Result switch
                        {
                            SimulationResult.Reported => "inbox-tag inbox-tag--safe",
                            SimulationResult.Clicked => "inbox-tag inbox-tag--danger",
                            SimulationResult.NoAction => "inbox-tag inbox-tag--muted",
                            _ => "inbox-tag inbox-tag--warning"
                        };
                        <tr>
                            <td>@sim.SentAt.ToString("MMM dd, yyyy")</td>
                            <td>@sim.Campaign.CampaignName</td>
                            <td>
                                <span class="inbox-tag inbox-tag--muted">
                                    @sim.Campaign.Difficulty
                                </span>
                            </td>
                            <td><span class="@resultPillClass">@resultText</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="pn-card-body text-center text-muted">
            No training history yet. Start by receiving your first test phish!
        </div>
    }
</div>

</div>
