@model PhishGuard.Models.SimulationEmail
@{
    ViewData["Title"] = "Simulation Result";
    var training = ViewBag.Training as PhishGuard.Models.EmployeeTraining;
    var caught = Model.Result == PhishGuard.Models.SimulationResult.Reported;
}

<div class="pn-page" style="max-width:760px;">
    <!-- Result Banner -->
    <div class="pn-card" style="border-top:3px solid @(caught ? "#50b583" : "#dc3545");">
        <div class="pn-card-body text-center" style="padding:32px 24px;">
            @if (caught)
            {
                <div style="font-size:1.3rem;font-weight:800;color:#50b583;">Great catch!</div>
                <p class="text-muted" style="margin:8px 0 0;font-size:0.9rem;">
                    You correctly identified this as a phishing email.
                    <strong>+@(Model.Campaign.Difficulty switch {
                        PhishGuard.Models.Difficulty.Easy => 5,
                        PhishGuard.Models.Difficulty.Medium => 10,
                        PhishGuard.Models.Difficulty.Hard => 20,
                        PhishGuard.Models.Difficulty.Expert => 40,
                        _ => 10
                    }) points earned!</strong>
                    @if (training != null)
                    {
                        <span>&bull; Streak: @training.CurrentStreak</span>
                    }
                </p>
            }
            else
            {
                <div style="font-size:1.3rem;font-weight:800;color:#dc3545;">This was a simulated phish</div>
                <p class="text-muted" style="margin:8px 0 0;font-size:0.9rem;">
                    Don't worry &mdash; no harm done. This is a training exercise. Your streak has been reset. Keep practicing!
                </p>
            }
        </div>
    </div>

    <!-- Learning Moment -->
    <div class="pn-card">
        <div class="pn-card-header">
            <h2 class="pn-card-title">What to look for</h2>
            @{
                var diffColor = Model.Campaign.Difficulty switch
                {
                    PhishGuard.Models.Difficulty.Easy => "#50b583",
                    PhishGuard.Models.Difficulty.Medium => "#d4920a",
                    PhishGuard.Models.Difficulty.Hard => "#c0392b",
                    PhishGuard.Models.Difficulty.Expert => "#6f42c1",
                    _ => "var(--pn-muted)"
                };
            }
            <span class="inbox-tag" style="background:@(diffColor)22;color:@diffColor;">@Model.Campaign.Difficulty</span>
        </div>
        <div class="pn-card-body">
            <div style="margin-bottom:12px;">
                <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em;">Sender</div>
                <div style="font-weight:600;color:#c0392b;">@Model.Campaign.TemplateSender</div>
            </div>
            <div style="margin-bottom:16px;">
                <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em;">Subject</div>
                <div style="font-weight:600;">@Model.Campaign.TemplateSubject</div>
            </div>
            <div class="text-muted" style="font-size:0.72rem;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px;">Red flags</div>
            <ul class="inbox-detail-reasons">
                @foreach (var indicator in Model.Campaign.PhishingIndicators.Split(';', StringSplitOptions.TrimEntries))
                {
                    <li>@indicator</li>
                }
            </ul>
        </div>
    </div>

    <div class="d-flex gap-2" style="margin-top:14px;">
        <a asp-action="Index" class="btn pn-btn">Back to Training</a>
        <a asp-action="Leaderboard" class="btn btn-outline-secondary">Leaderboard</a>
    </div>
</div>
