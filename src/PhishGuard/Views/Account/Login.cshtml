@model PhishGuard.Models.ViewModels.LoginViewModel
@{ ViewData["Title"] = "Login"; }

<div class="pn-auth-wrapper">
    <div class="pn-auth-card">
        <div class="pn-auth-header">
            <span class="pn-auth-brand">Phish<span class="pn-auth-accent">NET</span></span>
            <p class="pn-auth-sub">Sign in to your account</p>
        </div>

        <div asp-validation-summary="All" class="text-danger mb-3" style="font-size:0.85rem;"></div>

        <form asp-action="Login" method="post">
            <div class="pn-form-group">
                <label asp-for="Email" class="pn-label">Email</label>
                <input asp-for="Email" class="pn-input" autofocus />
                <span asp-validation-for="Email" class="text-danger" style="font-size:0.8rem;"></span>
            </div>
            <div class="pn-form-group">
                <label asp-for="Password" class="pn-label">Password</label>
                <input asp-for="Password" type="password" class="pn-input" />
                <span asp-validation-for="Password" class="text-danger" style="font-size:0.8rem;"></span>
            </div>
            <button type="submit" class="btn pn-btn w-100" style="padding:10px;">Sign in</button>
        </form>

        <div class="pn-auth-footer">
            Don't have an account? <a asp-action="Register" class="pn-auth-link">Register</a>
        </div>
    </div>
</div>
