@model PhishGuard.Models.ViewModels.UrlCheckViewModel
@{ ViewData["Title"] = "URL Check Result"; }

<div class="pn-page">
    <div class="pn-page-header">
        <div>
            <h1 class="pn-page-title">URL Check Result</h1>
            <p class="pn-page-subtitle">Verdict and breakdown for the link you checked.</p>
        </div>
        <div class="pn-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">Check Another URL</a>
            @if (Model.EmailId.HasValue)
            {
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">Back to Inbox</a>
            }
            @if (Model.IsSafe)
            {
                <a href="@Model.Url" target="_blank" rel="noopener noreferrer" class="btn pn-btn">Proceed</a>
            }
        </div>
    </div>

    <div class="pn-card" style="max-width: 980px;">
        <div class="pn-card-body">
            @{
                var verdictColor = Model.ThreatScore >= 70 ? "#dc3545" : Model.ThreatScore >= 30 ? "#d4920a" : "#1ca8c7";
                var verdictLabel = Model.ThreatScore >= 70 ? "High Risk" : Model.ThreatScore >= 30 ? "Suspicious" : "Low Risk";
            }
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <div style="font-weight:800;font-size:1.05rem;color:@verdictColor">@verdictLabel</div>
                    <div class="text-muted" style="font-size:0.86rem;">Threat Score: <strong>@Model.ThreatScore</strong> / 100</div>
                </div>
                <div style="flex:1;min-width:260px;max-width:520px;">
                    <div class="inbox-score-bar" style="height:8px;">
                        <div class="inbox-score-fill" style="width:@Model.ThreatScore%;background:@verdictColor;"></div>
                    </div>
                    <div class="d-flex justify-content-between" style="font-size:0.72rem;color:var(--pn-muted);margin-top:6px;">
                        <span>Safe</span><span>Dangerous</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="pn-card" style="max-width: 980px;">
        <div class="pn-card-header">
            <h2 class="pn-card-title">Details</h2>
        </div>
        <div class="pn-card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="text-muted" style="font-size:0.72rem;letter-spacing:0.08em;text-transform:uppercase;">URL Checked</div>
                    <div class="text-break" style="font-weight:600;">@Model.Url</div>
                </div>
                <div class="col-md-6">
                    <div class="text-muted" style="font-size:0.72rem;letter-spacing:0.08em;text-transform:uppercase;">Domain</div>
                    <div style="font-weight:600;">@Model.Domain</div>
                </div>
                @if (Model.FinalUrl != null && Model.FinalUrl != Model.Url)
                {
                    <div class="col-12">
                        <div class="text-muted" style="font-size:0.72rem;letter-spacing:0.08em;text-transform:uppercase;">Redirects To</div>
                        <div class="text-break" style="font-weight:600;">@Model.FinalUrl</div>
                    </div>
                }
                @if (Model.TriggersDownload)
                {
                    <div class="col-12">
                        <div class="inbox-tag inbox-tag--danger d-inline-flex align-items-center" style="gap:6px;">
                            File download detected
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="pn-card" style="max-width: 980px;">
        <div class="pn-card-header">
            <h2 class="pn-card-title">Findings</h2>
        </div>
        <div class="pn-card-body">
            @if (Model.Reasons.Any())
            {
                <ul class="inbox-detail-reasons" style="margin:0;">
                    @foreach (var reason in Model.Reasons)
                    {
                        <li>@reason</li>
                    }
                </ul>
            }
            else
            {
                <div class="text-muted">No issues found during analysis.</div>
            }
        </div>
    </div>
</div>
