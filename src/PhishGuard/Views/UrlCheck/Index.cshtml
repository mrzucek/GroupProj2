@{ ViewData["Title"] = "URL Safety Check"; }

<div class="pn-page">
    <div class="pn-page-header">
        <div>
            <h1 class="pn-page-title">URL Check</h1>
            <p class="pn-page-subtitle">Paste a link to check for known threats, suspicious domains, redirects, and file downloads.</p>
        </div>
    </div>

    <div class="pn-card" style="max-width: 860px;">
        <div class="pn-card-body">
            <form asp-action="CheckPost" method="post" class="d-flex gap-2 flex-wrap">
                <input type="text" name="url" class="pn-input" placeholder="https://example.com/suspicious-link" autofocus required style="flex:1;min-width:260px;" />
                <button type="submit" class="btn pn-btn">Check URL</button>
            </form>
        </div>
    </div>
</div>
